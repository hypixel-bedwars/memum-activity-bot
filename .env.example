########################################
# Core Application
########################################

DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_GUILD_ID

DATABASE_URL=postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Example:
# DATABASE_URL=postgres://postgres:password@localhost:5432/memum_activity_bot
# 
OWNERS=Discord_user_id_of_owner

########################################
# Hypixel API
########################################

HYPIXEL_API_KEY=your_hypixel_api_key_here

# Enables/disables the automatic Hypixel sweeper
ENABLE_HYPIXEL_SWEEPER=false

# Time between full sweep cycles
HYPIXEL_SWEEP_INTERVAL_SECONDS=60

# Minimum time between API refreshes per user
HYPIXEL_REFRESH_COOLDOWN_SECONDS=15

########################################
# Leveling System
########################################

# Base XP required for level 1
BASE_LEVEL_XP=100

# Level scaling factor
LEVEL_EXPONENT=1.5

########################################
# Message Validation
########################################

# Minimum message length to count for XP
MIN_MESSAGE_LENGTH=8

# Cooldown between XP-giving messages
MESSAGE_COOLDOWN_SECONDS=30


########################################
# Leaderboards
########################################

# How long leaderboard images stay cached
LEADERBOARD_CACHE_SECONDS=60

# Total players shown in persistent leaderboards
# (10 players per page)
PERSISTENT_LEADERBOARD_PLAYERS=10


########################################
# Admin Permissions
########################################

# Comma-separated Discord role IDs allowed to run admin commands
# (/edit-stats, /set-register-role, /leaderboard_create, /leaderboard_remove)
ADMIN_ROLE_IDS=