DISCORD_TOKEN=your_discord_bot_token_here
HYPIXEL_API_KEY=your_hypixel_api_key_here
DATABASE_URL=postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE 
# Example DATABASE_URL:
# DATABASE_URL=postgres://postgres:password@localhost:5432/memum_activity_bot
GUILD_ID=your_GUILD_ID

HYPIXEL_SWEEP_INTERVAL_SECONDS=60
DISCORD_SWEEP_INTERVAL_SECONDS=15

# Leveling system configuration
BASE_LEVEL_XP=100
LEVEL_EXPONENT=1.5

# Comma-separated Discord user IDs allowed to use admin commands (/edit-stats, /set-register-role, /leaderboard_create, /leaderboard_remove)
ADMIN_USER_IDS=

# Leaderboard settings
# How long (seconds) cached leaderboard images are valid before regeneration
LEADERBOARD_CACHE_SECONDS=60
# Total number of players shown in persistent leaderboards (10 per page)
PERSISTENT_LEADERBOARD_PLAYERS=10

# Message validation settings
MIN_MESSAGE_LENGTH=8
MESSAGE_COOLDOWN_SECONDS=30